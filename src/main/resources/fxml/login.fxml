<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.studybuddy.controller.LoginController"
            styleClass="root">

    <!-- LEFT PANEL -->

    <left>

        <VBox alignment="CENTER"
              spacing="20"
              styleClass="left-panel">

            <Label text="Virtual Study Buddy"
                   styleClass="big-title"/>

            <Label text="AI Powered Learning Companion"
                   styleClass="subtitle"/>

        </VBox>

    </left>


    <!-- LOGIN AREA -->

    <center>

        <StackPane>

            <VBox alignment="CENTER"
                  spacing="18"
                  maxWidth="350"
                  styleClass="login-card">

                <Label text="Welcome Back"
                       styleClass="login-title"/>


                <!-- EMAIL -->

                <TextField fx:id="emailField"
                           promptText="Email Address"
                           styleClass="input"/>


                <!-- PASSWORD -->

                <PasswordField fx:id="passwordField"
                               promptText="Password"
                               styleClass="input"/>


                <!-- LOGIN BUTTON -->

                <Button text="Login"
                        styleClass="login-btn"
                        onAction="#handleLogin"/>

                        <Label text="Create new account"
       onMouseClicked="#openSignupPage"
       styleClass="link"/>


                <!-- ERROR MESSAGE -->

                <Label fx:id="errorLabel"
                       textFill="red"
                       visible="false"/>


                <!-- FORGOT PASSWORD -->

                <Label text="Forgot Password?"
                       styleClass="link"/>


                <!-- SIGNUP LINK -->

                <HBox alignment="CENTER"
                      spacing="5">

                    <Label text="Don't have an account?"/>

                    <Label text="Sign Up"
                           styleClass="link"
                           onMouseClicked="#openSignupPage"/>

                </HBox>

            </VBox>

        </StackPane>

    </center>

</BorderPane>